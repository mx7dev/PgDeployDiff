<UserControl x:Class="PgDeployDiff.App.Controls.DiffViewer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo: ORIGEN -->
        <DockPanel Grid.Column="0">
            <TextBlock DockPanel.Dock="Top"
                       Text="ORIGEN"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Foreground="#C62828"
                       Margin="4,0,0,2"/>
            <Border BorderBrush="#C62828" BorderThickness="1">
                <ScrollViewer x:Name="OldScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="OnOldScrollChanged">
                    <ItemsControl x:Name="OldLines">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#EEEEEE" Padding="4,1">
                                        <TextBlock Text="{Binding LineNumberText}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Right"/>
                                    </Border>
                                    <Border Grid.Column="1" Background="{Binding Background}" Padding="6,1">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   TextWrapping="NoWrap"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>

        <!-- Separador -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource MaterialDesignDivider}"/>

        <!-- Panel derecho: DESTINO -->
        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top"
                       Text="DESTINO"
                       Style="{StaticResource MaterialDesignOverlineTextBlock}"
                       Foreground="#2E7D32"
                       Margin="4,0,0,2"/>
            <Border BorderBrush="#2E7D32" BorderThickness="1">
                <ScrollViewer x:Name="NewScroll"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="OnNewScrollChanged">
                    <ItemsControl x:Name="NewLines">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#EEEEEE" Padding="4,1">
                                        <TextBlock Text="{Binding LineNumberText}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="#888888"
                                                   HorizontalAlignment="Right"/>
                                    </Border>
                                    <Border Grid.Column="1" Background="{Binding Background}" Padding="6,1">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   TextWrapping="NoWrap"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Grid>
</UserControl>
