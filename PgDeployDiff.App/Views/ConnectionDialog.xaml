<Window x:Class="PgDeployDiff.App.Views.ConnectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Style="{StaticResource MaterialDesignWindow}"
        Title="Configurar conexión"
        Width="440"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Servidor + Puerto -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     materialDesign:HintAssist.Hint="Servidor"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBox Grid.Column="2"
                     materialDesign:HintAssist.Hint="Puerto"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <!-- Base de datos -->
        <TextBox Grid.Row="1" Margin="0,0,0,12"
                 materialDesign:HintAssist.Hint="Base de datos"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Usuario -->
        <TextBox Grid.Row="2" Margin="0,0,0,12"
                 materialDesign:HintAssist.Hint="Usuario"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Contraseña -->
        <PasswordBox Grid.Row="3" Margin="0,0,0,4"
                     x:Name="PwdBox"
                     materialDesign:HintAssist.Hint="Contraseña"
                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                     PasswordChanged="PwdBox_PasswordChanged"/>

        <!-- Guardar contraseña -->
        <CheckBox Grid.Row="4" Margin="2,6,0,16"
                  Content="Guardar contraseña"
                  IsChecked="{Binding SavePassword}"/>

        <!-- Botón probar conexión + spinner -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,6">
            <Button Content="PROBAR CONEXIÓN"
                    Command="{Binding TestConnectionCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Margin="0,0,12,0"/>
            <ProgressBar IsIndeterminate="True"
                         Width="80" VerticalAlignment="Center"
                         Visibility="{Binding IsTesting, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- Resultado del test -->
        <TextBlock Grid.Row="6"
                   Text="{Binding TestStatus}"
                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                   TextWrapping="Wrap"
                   MinHeight="20"
                   Margin="0,0,0,20"/>

        <!-- OK / Cancelar -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="ACEPTAR"
                    IsDefault="True"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Margin="0,0,8,0"
                    Click="OnOkClick"/>
            <Button Content="CANCELAR"
                    IsCancel="True"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="OnCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
